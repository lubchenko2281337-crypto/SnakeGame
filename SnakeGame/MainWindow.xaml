<Window x:Class="SnakeGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Змейка"
        Height="640"
        Width="560"
        MinWidth="480"
        MinHeight="520"
        Background="#FF2D2D30"
        Focusable="True"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="Space" Command="{Binding PauseCommand}" />
    </Window.InputBindings>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="6"
                Background="#FF3E3E42"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Foreground="#FFB0B0B0" FontSize="13" Text="Счёт: " />
                        <TextBlock Foreground="White" FontSize="13" FontWeight="SemiBold" Text="{Binding Score}" />
                        <TextBlock Foreground="#FFB0B0B0" FontSize="13" Margin="16,0,0,0" Text="Рекорд: " />
                        <TextBlock Foreground="#FFFFC107" FontSize="13" FontWeight="SemiBold" Text="{Binding BestScore}" />
                    </StackPanel>
                    <TextBlock Foreground="#FFCCCCCC" FontSize="12" Text="{Binding StatusText}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right">
                    <TextBlock Foreground="#FFB0B0B0" FontSize="11" Margin="0,0,0,4" Text="Режим" HorizontalAlignment="Right" />
                    <ComboBox Width="220"
                              ItemsSource="{Binding GameModeOptions}"
                              DisplayMemberPath="Title"
                              SelectedValuePath="Mode"
                              SelectedValue="{Binding GameMode}"
                              IsEnabled="{Binding CanChangeSettings}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="#FF555555"
                BorderThickness="2"
                CornerRadius="4"
                Background="#FF1E1E1E"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Canvas Width="{Binding CanvasPixelWidth}" Height="{Binding CanvasPixelHeight}" ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding SnakeSegments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="{Binding DataContext.CanvasPixelWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Height="{Binding DataContext.CanvasPixelHeight, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Rectangle Width="{Binding DataContext.CellSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Height="{Binding DataContext.CellSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       RadiusX="3"
                                       RadiusY="3"
                                       Fill="#FF66BB6A"
                                       Stroke="#FF2E7D32"
                                       StrokeThickness="1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Ellipse Width="{Binding CellSize}"
                         Height="{Binding CellSize}"
                         Canvas.Left="{Binding FoodLeft}"
                         Canvas.Top="{Binding FoodTop}"
                         Fill="#FFEF5350"
                         Stroke="#FFB71C1C"
                         StrokeThickness="1" />
            </Canvas>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,14,0,0">
            <Button MinWidth="110"
                    Margin="6"
                    Padding="12,6"
                    Content="Старт"
                    Command="{Binding StartGameCommand}" />
            <Button MinWidth="110"
                    Margin="6"
                    Padding="12,6"
                    Content="{Binding PauseButtonText}"
                    Command="{Binding PauseCommand}" />
            <Button MinWidth="110"
                    Margin="6"
                    Padding="12,6"
                    Content="Заново"
                    Command="{Binding RestartCommand}" />
        </StackPanel>
    </Grid>
</Window>
